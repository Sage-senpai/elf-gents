# --- CROO / CAP -----------------------------------------------------------
# Get these from the CROO dashboard at https://agent.croo.network:
#   My Agents -> Register Agent  (generates an AA wallet + Agent DID + SDK key).
# Leave CROO_SDK_KEY blank to run the agent in MOCK mode (no network, no payments).
CROO_API_URL="https://api.croo.network"
CROO_WS_URL="wss://api.croo.network/ws"
BASE_RPC_URL="https://mainnet.base.org"   # Base mainnet; CAP settles on Base
CROO_SDK_KEY=""                            # croo_sk_...
CROO_TARGET_SERVICE_ID=""                  # requester/demo only: the service id to hire

# Service pricing (registered in the dashboard; mirrored here for the banner)
SERVICE_PRICE_USDC="1.00"                  # verify: one claim-check
RECON_PRICE_USDC="3.00"                    # recon: one prior-art research report
VALIDATE_PRICE_USDC="0.50"                 # validate: one deliverable conformance check

# Which service the MOCK client simulates a paid order for: verify | recon | validate
MOCK_SERVICE="verify"

# --- Agent wallet (signs the provenance receipt) --------------------------
# A throwaway key is fine for the hackathon. NEVER commit a funded mainnet key.
# (This signs receipts only — the CAP payment wallet is the AA wallet you fund
#  in the dashboard, not this key.)
AGENT_WALLET_PRIVATE_KEY=""                # 0x... — node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"

# --- GitHub (REQUIRED for the recon service) ------------------------------
# The recon service genuinely calls the GitHub API. Mint a token at
# https://github.com/settings/tokens (a classic token with `public_repo`
# scope, or a fine-grained token with public read, is enough).
GITHUB_TOKEN=""                            # ghp_... / github_pat_...

# --- Inference (verification judgement + recon synthesis) -----------------
# Optional. Without it: verify falls back to a deterministic heuristic, and
# recon returns ranked repos with heuristic notes instead of model-written ones.

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
