# --- CROO / CAP -----------------------------------------------------------
# Get these from the CROO dashboard: Dashboard -> My Agents -> Register Agent.
# Leave them blank to run the agent in MOCK mode (no network, no payments).
CROO_API_URL="https://api.croo.network"
CROO_WS_URL="wss://api.croo.network/ws"
CROO_SDK_KEY=""                 # croo_sk_...

# Service config
SERVICE_PRICE_USDC="1.00"       # what one verification job costs

# --- Agent wallet (signs the provenance receipt) --------------------------
# A throwaway key is fine for the hackathon. NEVER commit a funded mainnet key.
AGENT_WALLET_PRIVATE_KEY=""      # 0x... — generate with: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"

# --- Inference (the verification judgement) -------------------------------
# Optional. Without it, the agent falls back to a deterministic mock verdict.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
